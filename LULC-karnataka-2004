// 1. Create class masks for RF classification
var waterMaskRF = classifiedRF.eq(1);
var vegetationMaskRF = classifiedRF.eq(2);
var builtupUrbanMaskRF = classifiedRF.eq(3);
var fallowMaskRF = classifiedRF.eq(4);
var barrenMaskRF = classifiedRF.eq(5);
var forestMaskRF = classifiedRF.eq(6);
var builtupRuralMaskRF = classifiedRF.eq(7);
var coastalLandMaskRF = classifiedRF.eq(8);

// 2. Calculate area in km²
var pixelArea = ee.Image.pixelArea().divide(1e6);  // Convert m² to km²

var waterAreaRF = pixelArea.updateMask(waterMaskRF);
var vegetationAreaRF = pixelArea.updateMask(vegetationMaskRF);
var builtupUrbanAreaRF = pixelArea.updateMask(builtupUrbanMaskRF);
var fallowAreaRF = pixelArea.updateMask(fallowMaskRF);
var barrenAreaRF = pixelArea.updateMask(barrenMaskRF);
var forestAreaRF = pixelArea.updateMask(forestMaskRF);
var builtupRuralAreaRF = pixelArea.updateMask(builtupRuralMaskRF);
var coastalLandAreaRF = pixelArea.updateMask(coastalLandMaskRF);

// 3. Function to compute total area for each class
function getArea(image) {
  return ee.Number(image.reduceRegion({
    reducer: ee.Reducer.sum(),
    geometry: table,
    scale: 30,
    maxPixels: 1e9
  }).values().get(0));
}

// 4. Calculate area values for RF
var waterSumRF = getArea(waterAreaRF);
var vegetationSumRF = getArea(vegetationAreaRF);
var builtupUrbanSumRF = getArea(builtupUrbanAreaRF);
var fallowSumRF = getArea(fallowAreaRF);
var barrenSumRF = getArea(barrenAreaRF);
var forestSumRF = getArea(forestAreaRF);
var builtupRuralSumRF = getArea(builtupRuralAreaRF);
var coastalLandSumRF = getArea(coastalLandAreaRF);

// 5. Create a FeatureCollection to store RF area values
var areaFeaturesRF = ee.FeatureCollection([
  ee.Feature(null, {class: 'Water', area_km2: waterSumRF}),
  ee.Feature(null, {class: 'Crop', area_km2: vegetationSumRF}),
  ee.Feature(null, {class: 'Built-up Urban', area_km2: builtupUrbanSumRF}),
  ee.Feature(null, {class: 'Fallow', area_km2: fallowSumRF}),
  ee.Feature(null, {class: 'Barren', area_km2: barrenSumRF}),
  ee.Feature(null, {class: 'Forest', area_km2: forestSumRF}),
  ee.Feature(null, {class: 'Built-up Rural', area_km2: builtupRuralSumRF}),
  ee.Feature(null, {class: 'Coastal Land', area_km2: coastalLandSumRF})
]);

// 6. Print readable results for RF
